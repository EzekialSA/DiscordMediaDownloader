# Discord user token (required)
DISCORD_TOKEN=your_discord_token_here

# Path to DiscordChatExporter CLI exe (Windows)
# Relative paths are resolved from the script's directory
DCE_PATH=.\DiscordChatExporter.Cli.exe

# Config directory (where export.csv and download.csv live)
# Defaults to the script's directory if not set
CONFIG_DIR=./config

# Output directory (where JSON exports and downloaded media go)
OUTPUT_DIR=./output
