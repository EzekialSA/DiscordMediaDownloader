# Discord user token (required)
DISCORD_TOKEN=your_discord_token_here

# Path to DiscordChatExporter CLI (default for Docker)
DCE_PATH=/opt/dce/DiscordChatExporter.Cli

# Config directory (where export.csv and download.csv live)
CONFIG_DIR=/config

# Output directory (where JSON exports and downloaded media go)
OUTPUT_DIR=/output
